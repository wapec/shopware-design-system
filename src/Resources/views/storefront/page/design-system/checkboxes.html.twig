{% block design_system_checkboxes %}
<h2 class="mb-3">Checkboxes, Radios &amp; Toggles</h2>
<p class="text-muted mb-4">Bootstrap <code>form-check</code> components including the <code>form-switch</code> variant.</p>

<div class="row g-4">

    {# Checkboxes #}
    <div class="col-md-4">
        <h5 class="mb-3">Checkboxes</h5>

        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="check-checked" checked>
            <label class="form-check-label" for="check-checked">Checked</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="check-unchecked">
            <label class="form-check-label" for="check-unchecked">Unchecked</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="check-indeterminate">
            <label class="form-check-label" for="check-indeterminate">Indeterminate</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="check-disabled-checked" checked disabled>
            <label class="form-check-label" for="check-disabled-checked">Disabled checked</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="check-disabled" disabled>
            <label class="form-check-label" for="check-disabled">Disabled unchecked</label>
        </div>

        <h6 class="mt-4 mb-2">Inline checkboxes</h6>
        <div class="d-flex gap-3 flex-wrap">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="inline-check-1" checked>
                <label class="form-check-label" for="inline-check-1">Option 1</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="inline-check-2">
                <label class="form-check-label" for="inline-check-2">Option 2</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="inline-check-3">
                <label class="form-check-label" for="inline-check-3">Option 3</label>
            </div>
        </div>

        <h6 class="mt-4 mb-2">Long label wrapping</h6>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="check-long">
            <label class="form-check-label" for="check-long">
                This is a checkbox with a very long label that wraps onto multiple lines to demonstrate
                how the form-check layout handles text overflow correctly.
            </label>
        </div>
    </div>

    {# Radios #}
    <div class="col-md-4">
        <h5 class="mb-3">Radio buttons</h5>

        <div class="form-check mb-2">
            <input class="form-check-input" type="radio" name="radio-group-1" id="radio-1" checked>
            <label class="form-check-label" for="radio-1">Selected option</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="radio" name="radio-group-1" id="radio-2">
            <label class="form-check-label" for="radio-2">Unselected option</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="radio" name="radio-group-1" id="radio-3">
            <label class="form-check-label" for="radio-3">Another option</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="radio" name="radio-disabled" id="radio-disabled-1" checked disabled>
            <label class="form-check-label" for="radio-disabled-1">Disabled selected</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="radio" name="radio-disabled" id="radio-disabled-2" disabled>
            <label class="form-check-label" for="radio-disabled-2">Disabled unselected</label>
        </div>

        <h6 class="mt-4 mb-2">Inline radios</h6>
        <div class="d-flex gap-3 flex-wrap">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="inline-radio" id="inline-r-1" checked>
                <label class="form-check-label" for="inline-r-1">Yes</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="inline-radio" id="inline-r-2">
                <label class="form-check-label" for="inline-r-2">No</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="inline-radio" id="inline-r-3">
                <label class="form-check-label" for="inline-r-3">Maybe</label>
            </div>
        </div>
    </div>

    {# Toggle switches #}
    <div class="col-md-4">
        <h5 class="mb-3">Toggle switches</h5>

        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" role="switch" id="switch-on" checked>
            <label class="form-check-label" for="switch-on">Enabled (on)</label>
        </div>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" role="switch" id="switch-off">
            <label class="form-check-label" for="switch-off">Disabled (off)</label>
        </div>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" role="switch" id="switch-disabled-on" checked disabled>
            <label class="form-check-label" for="switch-disabled-on">Disabled on</label>
        </div>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" role="switch" id="switch-disabled-off" disabled>
            <label class="form-check-label" for="switch-disabled-off">Disabled off</label>
        </div>

        <h6 class="mt-4 mb-2">Newsletter example</h6>
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switch-newsletter" checked>
            <label class="form-check-label" for="switch-newsletter">
                Subscribe to newsletter
            </label>
        </div>
        <div class="form-check form-switch mt-2">
            <input class="form-check-input" type="checkbox" role="switch" id="switch-gdpr">
            <label class="form-check-label" for="switch-gdpr">
                I agree to the <a href="#">privacy policy</a>
            </label>
        </div>
    </div>

</div>
{% endblock %}
