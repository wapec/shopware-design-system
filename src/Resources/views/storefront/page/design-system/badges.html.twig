{% block design_system_badges %}
<h2 class="mb-3">Badges</h2>
<p class="text-muted mb-4">Use <code>badge</code> with a contextual modifier to label or count items.</p>

<h5 class="mb-2">Solid badges</h5>
<div class="d-flex flex-wrap gap-2 mb-4">
    {% for variant in ['primary', 'secondary', 'success', 'danger', 'warning', 'info', 'light', 'dark'] %}
        <span class="badge text-bg-{{ variant }}">{{ variant }}</span>
    {% endfor %}
</div>

<h5 class="mb-2">Pill badges</h5>
<div class="d-flex flex-wrap gap-2 mb-4">
    {% for variant in ['primary', 'secondary', 'success', 'danger', 'warning', 'info', 'light', 'dark'] %}
        <span class="badge rounded-pill text-bg-{{ variant }}">{{ variant }}</span>
    {% endfor %}
</div>

<h5 class="mb-2">Badges inside headings</h5>
<div class="mb-4">
    <h4>New arrivals <span class="badge text-bg-primary">12</span></h4>
    <h5>On sale <span class="badge text-bg-danger">Hot</span></h5>
    <h6>In stock <span class="badge text-bg-success">Available</span></h6>
</div>

<h5 class="mb-2">Badges on buttons</h5>
<div class="d-flex flex-wrap gap-3 mb-4">
    <button type="button" class="btn btn-primary position-relative">
        Cart
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-danger">
            3<span class="visually-hidden">items in cart</span>
        </span>
    </button>
    <button type="button" class="btn btn-outline-secondary position-relative">
        Wishlist
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-primary">
            5<span class="visually-hidden">saved items</span>
        </span>
    </button>
    <button type="button" class="btn btn-secondary">
        Notifications <span class="badge text-bg-light ms-1">99+</span>
    </button>
</div>

<h5 class="mb-2">Status indicators</h5>
<div class="d-flex flex-wrap gap-2">
    <span class="badge text-bg-success">In stock</span>
    <span class="badge text-bg-warning">Low stock</span>
    <span class="badge text-bg-danger">Out of stock</span>
    <span class="badge text-bg-info">Pre-order</span>
    <span class="badge text-bg-secondary">Discontinued</span>
    <span class="badge text-bg-dark">New</span>
</div>
{% endblock %}
