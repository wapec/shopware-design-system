{% block design_system_cards %}
<h2 class="mb-3">Cards</h2>
<p class="text-muted mb-4">Bootstrap <code>card</code> component as used for product tiles, account panels, and CMS blocks.</p>

<h5 class="mb-3">Basic card</h5>
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Card title</h5>
                <p class="card-text">Basic card with body only. Useful for simple content blocks.</p>
                <a href="#" class="btn btn-primary btn-sm">Go somewhere</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header">Featured</div>
            <div class="card-body">
                <h5 class="card-title">Card with header</h5>
                <p class="card-text">The <code>card-header</code> provides a labelled section at the top.</p>
                <a href="#" class="btn btn-outline-primary btn-sm">Learn more</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Card with footer</h5>
                <p class="card-text">The <code>card-footer</code> anchors metadata at the bottom.</p>
            </div>
            <div class="card-footer text-muted">
                Last updated 3 mins ago
            </div>
        </div>
    </div>
</div>

<h5 class="mb-3">Product-style card</h5>
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-md-4 col-lg-3">
        <div class="card h-100">
            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                {% sw_icon 'shopping-bag' style { pack: 'default', width: '64px', height: '64px' } %}
            </div>
            <div class="card-body d-flex flex-column">
                <h6 class="card-title">Sample Product Name</h6>
                <p class="card-text text-muted small flex-grow-1">Short product description line that wraps naturally.</p>
                <div class="d-flex align-items-center justify-content-between mt-3">
                    <span class="fw-bold">€29.99</span>
                    <button type="button" class="btn btn-primary btn-sm d-inline-flex align-items-center gap-1">
                        {% sw_icon 'cart' style { pack: 'default' } %}
                        Add
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-4 col-lg-3">
        <div class="card h-100">
            <div class="bg-light d-flex align-items-center justify-content-center position-relative" style="height: 180px;">
                {% sw_icon 'shopping-bag' style { pack: 'default', width: '64px', height: '64px' } %}
                <span class="position-absolute top-0 end-0 m-2 badge text-bg-danger">Sale</span>
            </div>
            <div class="card-body d-flex flex-column">
                <h6 class="card-title">Product with Badge</h6>
                <p class="card-text text-muted small flex-grow-1">Product on promotion with a sale badge.</p>
                <div class="d-flex align-items-center justify-content-between mt-3">
                    <div>
                        <span class="fw-bold text-danger">€19.99</span>
                        <small class="text-decoration-line-through text-muted ms-1">€29.99</small>
                    </div>
                    <button type="button" class="btn btn-primary btn-sm d-inline-flex align-items-center gap-1">
                        {% sw_icon 'cart' style { pack: 'default' } %}
                        Add
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-4 col-lg-3">
        <div class="card h-100">
            <div class="bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="height: 180px;">
                {% sw_icon 'shopping-bag' style { pack: 'default', width: '64px', height: '64px' } %}
            </div>
            <div class="card-body d-flex flex-column">
                <h6 class="card-title">Out of Stock Product</h6>
                <p class="card-text text-muted small flex-grow-1">Unavailable product with disabled add-to-cart.</p>
                <div class="d-flex align-items-center justify-content-between mt-3">
                    <span class="fw-bold text-muted">€49.99</span>
                    <button type="button" class="btn btn-secondary btn-sm" disabled>Out of stock</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-4 col-lg-3">
        <div class="card h-100 border-primary">
            <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between">
                <span>Featured</span>
                {% sw_icon 'star' style { pack: 'default' } %}
            </div>
            <div class="card-body d-flex flex-column">
                <h6 class="card-title">Featured Product</h6>
                <p class="card-text text-muted small flex-grow-1">Highlighted with a coloured border and header.</p>
                <div class="d-flex align-items-center justify-content-between mt-3">
                    <span class="fw-bold">€39.99</span>
                    <button type="button" class="btn btn-primary btn-sm d-inline-flex align-items-center gap-1">
                        {% sw_icon 'cart' style { pack: 'default' } %}
                        Add
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<h5 class="mb-3">Account / info panels</h5>
<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                {% sw_icon 'profile' style { pack: 'default' } %}
                Personal data
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">Jane Doe</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">jane@example.com</dd>
                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">+1 555 123 456</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-end">
                <a href="#" class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-1">
                    {% sw_icon 'pencil' style { pack: 'default' } %}
                    Edit
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-success">
            <div class="card-header bg-success text-white d-flex align-items-center gap-2">
                {% sw_icon 'checkmark-circle' style { pack: 'default' } %}
                Order confirmed
            </div>
            <div class="card-body">
                <h6 class="card-title">Order #10042</h6>
                <p class="card-text text-muted small">Placed on 5 May 2026. Estimated delivery in 2–4 business days.</p>
                <a href="#" class="btn btn-success btn-sm">View order</a>
                <a href="#" class="btn btn-outline-secondary btn-sm ms-1">Track shipment</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
