{% block design_system_typography %}
<h2 class="mb-3">Typography</h2>
<p class="text-muted mb-4">Standard heading and body text hierarchy.</p>

<h5 class="mb-2">Headings</h5>
<h1>Heading 1 <small class="text-muted fs-6 fw-normal">h1</small></h1>
<h2>Heading 2 <small class="text-muted fs-6 fw-normal">h2</small></h2>
<h3>Heading 3 <small class="text-muted fs-6 fw-normal">h3</small></h3>
<h4>Heading 4 <small class="text-muted fs-6 fw-normal">h4</small></h4>
<h5>Heading 5 <small class="text-muted fs-6 fw-normal">h5</small></h5>
<h6>Heading 6 <small class="text-muted fs-6 fw-normal">h6</small></h6>

<hr>

<h5 class="mb-2">Display sizes</h5>
<div class="display-1">Display 1</div>
<div class="display-2">Display 2</div>
<div class="display-3">Display 3</div>
<div class="display-4">Display 4</div>

<hr>

<h5 class="mb-2">Body text</h5>
<p class="lead">Lead paragraph — slightly larger and lighter.</p>
<p>
    Regular paragraph. Lorem ipsum dolor sit amet, consectetur adipiscing elit,
    sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
    Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.
</p>
<p><small>Small text via <code>&lt;small&gt;</code> or <code>.small</code>.</small></p>
<p><strong>Bold text</strong> and <em>italic text</em> and <a href="#">a hyperlink</a>.</p>
<p><mark>Highlighted text</mark> and <del>deleted text</del> and <ins>inserted text</ins>.</p>
<p><code>inline code</code> and <kbd>Ctrl+C</kbd> keyboard shortcut.</p>

<hr>

<h5 class="mb-2">Lists</h5>
<div class="row g-4">
    <div class="col-md-4">
        <h6>Unordered list</h6>
        <ul>
            <li>Item one</li>
            <li>Item two
                <ul>
                    <li>Nested item</li>
                    <li>Nested item</li>
                </ul>
            </li>
            <li>Item three</li>
        </ul>
    </div>
    <div class="col-md-4">
        <h6>Ordered list</h6>
        <ol>
            <li>First item</li>
            <li>Second item</li>
            <li>Third item</li>
        </ol>
    </div>
    <div class="col-md-4">
        <h6>Unstyled list</h6>
        <ul class="list-unstyled">
            <li>No bullet</li>
            <li>No bullet</li>
            <li>No bullet</li>
        </ul>
    </div>
</div>

<hr>

<h5 class="mb-2">Blockquote</h5>
<blockquote class="blockquote">
    <p>A well-known quote, contained in a blockquote element.</p>
    <footer class="blockquote-footer">Someone famous in <cite title="Source Title">Source Title</cite></footer>
</blockquote>
{% endblock %}
