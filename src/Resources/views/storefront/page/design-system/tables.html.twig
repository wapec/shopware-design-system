{% block design_system_tables %}
<h2 class="mb-3">Tables</h2>
<p class="text-muted mb-4">Bootstrap table modifiers used for order history, line items, and data listings.</p>

<h5 class="mb-2">Default table</h5>
<div class="table-responsive mb-4">
    <table class="table">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Product</th>
                <th scope="col">SKU</th>
                <th scope="col">Qty</th>
                <th scope="col" class="text-end">Price</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <th scope="row">1</th>
                <td>Sample Product A</td>
                <td><code>SKU-001</code></td>
                <td>2</td>
                <td class="text-end">€29.98</td>
            </tr>
            <tr>
                <th scope="row">2</th>
                <td>Sample Product B</td>
                <td><code>SKU-002</code></td>
                <td>1</td>
                <td class="text-end">€14.99</td>
            </tr>
            <tr>
                <th scope="row">3</th>
                <td>Sample Product C</td>
                <td><code>SKU-003</code></td>
                <td>3</td>
                <td class="text-end">€44.97</td>
            </tr>
        </tbody>
        <tfoot>
            <tr class="fw-bold">
                <td colspan="4" class="text-end">Total</td>
                <td class="text-end">€89.94</td>
            </tr>
        </tfoot>
    </table>
</div>

<h5 class="mb-2">Striped rows</h5>
<div class="table-responsive mb-4">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th scope="col">Order</th>
                <th scope="col">Date</th>
                <th scope="col">Status</th>
                <th scope="col" class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
            {% set orders = [
                { id: '#10042', date: '2026-05-01', status: 'Delivered',  badge: 'success'   },
                { id: '#10041', date: '2026-04-18', status: 'Shipped',    badge: 'info'      },
                { id: '#10040', date: '2026-04-02', status: 'Processing', badge: 'warning'   },
                { id: '#10039', date: '2026-03-15', status: 'Cancelled',  badge: 'danger'    },
                { id: '#10038', date: '2026-03-01', status: 'Delivered',  badge: 'success'   },
            ] %}
            {% for order in orders %}
                <tr>
                    <td><a href="#">{{ order.id }}</a></td>
                    <td>{{ order.date }}</td>
                    <td><span class="badge text-bg-{{ order.badge }}">{{ order.status }}</span></td>
                    <td class="text-end">€{{ (loop.index * 19.99)|number_format(2) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<h5 class="mb-2">Bordered + small + contextual rows</h5>
<div class="table-responsive mb-4">
    <table class="table table-bordered table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th scope="col">Item</th>
                <th scope="col">Stock</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr class="table-success">
                <td>Product A</td>
                <td><span class="badge text-bg-success">In stock (120)</span></td>
                <td class="text-end">
                    <button class="btn btn-outline-primary btn-sm">Edit</button>
                </td>
            </tr>
            <tr class="table-warning">
                <td>Product B</td>
                <td><span class="badge text-bg-warning">Low stock (4)</span></td>
                <td class="text-end">
                    <button class="btn btn-outline-primary btn-sm">Edit</button>
                </td>
            </tr>
            <tr class="table-danger">
                <td>Product C</td>
                <td><span class="badge text-bg-danger">Out of stock</span></td>
                <td class="text-end">
                    <button class="btn btn-outline-primary btn-sm">Edit</button>
                </td>
            </tr>
            <tr>
                <td>Product D</td>
                <td><span class="badge text-bg-secondary">Discontinued</span></td>
                <td class="text-end">
                    <button class="btn btn-outline-secondary btn-sm" disabled>Edit</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<h5 class="mb-2">Responsive (scroll on small screens)</h5>
<p class="text-muted small">Wrap any <code>.table</code> in <code>.table-responsive</code> to enable horizontal scrolling below the breakpoint of your choice (<code>table-responsive-{sm|md|lg|xl|xxl}</code>).</p>
<div class="table-responsive-md">
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                {% for col in ['ID', 'Name', 'Email', 'City', 'Country', 'Orders', 'Spent', 'Last order'] %}
                    <th scope="col">{{ col }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for i in 1..3 %}
                <tr>
                    <td>{{ 1000 + i }}</td>
                    <td>Customer {{ i }}</td>
                    <td>customer{{ i }}@example.com</td>
                    <td>Berlin</td>
                    <td>Germany</td>
                    <td>{{ i * 3 }}</td>
                    <td>€{{ (i * 59.99)|number_format(2) }}</td>
                    <td>2026-05-0{{ i }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
